 {
	    "name": "mysite",
	    "compatibility_date": "2026-07-17",
	    "assets": {
	      "directory": "./dist",
        "binding": "ASSETS",
        "html_handling": "drop-trailing-slash",
    "not_found_handling": "single-page-application"
	    },
       
 "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": true
    }
  }

	  }